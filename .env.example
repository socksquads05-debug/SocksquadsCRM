# SocksQuads CRM - Environment Variables Template
# Copy this file to .env and fill in your values
# For local development only - never commit .env to GitHub

# Google Sheets Configuration
GOOGLE_SHEET_NAME=SocksQuads CRM

# Application Settings
APP_ENV=local  # local or production
DEBUG=true

# Session Configuration
SESSION_TIMEOUT=3600

# Note: For Google Credentials, use Streamlit Secrets on Cloud
# For local development, place credentials.json in project root
